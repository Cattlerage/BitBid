generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum ListingStatus {
  DRAFT
  ACTIVE
  ENDED
  CANCELLED
}

model User {
  id          String    @id @default(uuid())
  name        String
  email       String    @unique

  listings    Listing[] @relation("SellerListings")
  wonListings Listing[] @relation("WinnerListings")
  bids        Bid[]         

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Listing {
  id          String        @id @default(uuid())
  title       String
  description String
  startingBid Int
  currentBid  Int           @default(0)
  status      ListingStatus @default(DRAFT)
  endTime     DateTime
  
  sellerId    String
  seller      User          @relation("SellerListings", fields: [sellerId], references: [id])

  winnerId    String?       
  winner      User?         @relation("WinnerListings", fields: [winnerId], references: [id]) 
  
  bids        Bid[]
  
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([status, endTime])
}

model Bid {
  id          String   @id @default(uuid())
  amount      Int
  
  listingId   String
  listing     Listing  @relation(fields: [listingId], references: [id])
  
  bidderId    String
  bidder      User     @relation(fields: [bidderId], references: [id])
  
  createdAt   DateTime @default(now())

  @@index([listingId, amount(sort: Desc)])
}